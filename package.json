{
  "name": "vide-digital-security-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "emulators": "firebase emulators:start --project demo-vide-hub",
    "test:rules": "firebase emulators:exec --project demo-vide-hub \"node --test tests/emulator/*.test.mjs\"",
    "test:functions": "node --test tests/functions/*.test.mjs",
    "test:security": "npm run test:rules && npm run test:functions",
    "smoke:release": "node tests/release-candidate-harness.mjs"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "firebase": "^11.1.0",
    "firebase-tools": "^13.29.1"
  }
}
