// Regras do Vide Hub.
//
// O projeto está no plano Blaze, mas a maior parte da escrita continua
// direta do cliente por decisão de arquitetura, não por limitação: é mais
// simples, mais rápido e igualmente seguro quando a regra consegue validar
// tudo sozinha (conteúdo público real, campos conhecidos, autoria derivada
// do contexto autenticado). Cloud Functions ficam reservadas para quando
// exista segredo, integração externa (IA/WhatsApp), operação administrativa
// privilegiada, rate limit confiável ou processamento assíncrono real —
// nada disso está implementado ainda.
// Trade-off consciente das escritas públicas (visitante anônimo): sem App
// Check nem rate limit de servidor — o alcance de abuso fica restrito ao
// próprio documento de métrica/lead/chat que a regra amarra.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(ownerUid) {
      return signedIn() && request.auth.uid == ownerUid;
    }

    // Contrato futuro: claims emitidas pelo Admin SDK/Cloud Functions.
    // O frontend pode usar equipe_admin para UX, mas rules não devem depender
    // de coleção manipulável pelo próprio cliente para conceder privilégio.
    function isBackendAdmin() {
      return signedIn()
        && request.auth.token.keys().hasAny(["videAdmin"])
        && request.auth.token.videAdmin == true;
    }

    function employeeExists() {
      return signedIn()
        && exists(/databases/$(database)/documents/funcionarios/$(request.auth.uid));
    }

    function employeeDoc() {
      return get(/databases/$(database)/documents/funcionarios/$(request.auth.uid));
    }

    function employeeHasPermissionShape(empData) {
      return empData.keys().hasAll(["status", "donoUID", "permissoes"])
        && empData.permissoes is map
        && empData.permissoes.keys().hasAll(["ver", "editar"])
        && empData.permissoes.ver is list
        && empData.permissoes.editar is list;
    }

    // Recebe empData (o funcionarios/{uid} já buscado) em vez de chamar
    // employeeDoc() de novo — as versões antigas dessas funções chamavam
    // employeeDoc() (um get()) até 10x numa única avaliação de canViewTenant,
    // estourando o limite de 10 get()/exists() por regra do Firestore e
    // travando com "evaluation error" o login de qualquer funcionário ativo.
    function isActiveEmployeeForData(ownerUid, empData) {
      return employeeHasPermissionShape(empData)
        && empData.status == "ativo"
        && empData.donoUID == ownerUid;
    }

    function isActiveEmployeeFor(ownerUid) {
      return employeeExists() && isActiveEmployeeForData(ownerUid, employeeDoc().data);
    }

    function employeeHasModulePermission(permissions, moduleKey) {
      return moduleKey in permissions
        || (moduleKey == "central-ia" && (
          "central_ia" in permissions
          || "gerenciar_ia" in permissions
          || "ia" in permissions
          || "inteligencia-artificial" in permissions
        ))
        || (moduleKey == "base-conhecimento-ia" && (
          "base_conhecimento_ia" in permissions
          || "conhecimento-ia" in permissions
          || "conhecimento_ia" in permissions
          || "knowledge-base" in permissions
          || "base-ia" in permissions
        ))
        || (moduleKey == "atendimento" && (
          "conversas" in permissions
          || "atendimento_chat" in permissions
          || "templates_atendimento" in permissions
        ));
    }

    function employeeCanView(ownerUid, moduleKey) {
      return employeeExists() && employeeCanViewData(ownerUid, moduleKey, employeeDoc().data);
    }

    function employeeCanViewData(ownerUid, moduleKey, empData) {
      return isActiveEmployeeForData(ownerUid, empData)
        && (
          employeeHasModulePermission(empData.permissoes.ver, moduleKey)
          || employeeHasModulePermission(empData.permissoes.editar, moduleKey)
        );
    }

    function employeeCanEdit(ownerUid, moduleKey) {
      return employeeExists() && employeeCanEditData(ownerUid, moduleKey, employeeDoc().data);
    }

    function employeeCanEditData(ownerUid, moduleKey, empData) {
      return isActiveEmployeeForData(ownerUid, empData)
        && employeeHasModulePermission(empData.permissoes.editar, moduleKey);
    }

    function canViewTenant(ownerUid, moduleKey) {
      return isOwner(ownerUid) || employeeCanView(ownerUid, moduleKey) || isBackendAdmin();
    }

    function canEditTenant(ownerUid, moduleKey) {
      return isOwner(ownerUid) || employeeCanEdit(ownerUid, moduleKey) || isBackendAdmin();
    }

    function validOwnerCreateKeys() {
      return request.resource.data.keys().hasOnly([
        "identificador",
        "nome",
        "email",
        "nomeLoja",
        "urlLoja",
        "status",
        "criadoEm",
        "uid",
        "donoUID"
      ]);
    }

    function validOwnerCreate(ownerUid) {
      return isOwner(ownerUid)
        && validOwnerCreateKeys()
        && request.resource.data.keys().hasAll(["identificador", "email", "nomeLoja", "urlLoja", "status", "criadoEm"])
        && request.resource.data.status == "pendente"
        && (!request.resource.data.keys().hasAny(["uid"]) || request.resource.data.uid == ownerUid)
        && (!request.resource.data.keys().hasAny(["donoUID"]) || request.resource.data.donoUID == ownerUid)
        && !request.resource.data.keys().hasAny([
          "plano",
          "featuresManuais",
          "role",
          "admin",
          "equipe",
          "aprovadoEm",
          "aprovadoPor",
          "bloqueado",
          "bloqueadoEm",
          "bloqueadoPor"
        ]);
    }

    function ownerProfileFields() {
      return [
        "identificador",
        "nome",
        "email",
        "nomeLoja",
        "urlLoja",
        "tituloHero",
        "subtituloHero",
        "whatsappCentral",
        "instagramUser",
        "tiktokUser",
        "youtubeUrl",
        "link1Titulo",
        "link1Url",
        "link1Icone",
        "link2Titulo",
        "link2Url",
        "link2Icone",
        "abaPadrao",
        "whatsappChat",
        "chatAtivo",
        "carrinhoAtivo",
        "carrinhoMensagem",
        "corDestaque",
        "corFundo",
        "corCard",
        "corSecundaria",
        "corTexto",
        "corTextoBotao",
        "corBorda",
        "fonteVitrine",
        "adminCorDestaque",
        "adminCorFundo",
        "adminCorTexto",
        "adminCorCard",
        "fotoPerfilB64",
        "layoutLojaPublica",
        "layoutPorAba",
        "atualizadoEm"
      ];
    }

    function adminOnlyFieldsUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        "status",
        "plano",
        "featuresManuais",
        "role",
        "admin",
        "equipe",
        "uid",
        "donoUID",
        "aprovadoEm",
        "aprovadoPor",
        "bloqueado",
        "bloqueadoEm",
        "bloqueadoPor"
      ]);
    }

    function validOwnerProfileUpdate(ownerUid) {
      return canEditTenant(ownerUid, "configuracoes")
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(ownerProfileFields())
        && adminOnlyFieldsUnchanged();
    }

    function criadoPorUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(["criadoPor"]);
    }

    function donoUIDUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(["donoUID"]);
    }

    // Quem pode ver uma notificação: admin.html grava "todos" ou uma lista
    // de UIDs específicos em destinatarios; nunca grava campo uid, mas a
    // regra aceita esse formato também por segurança futura.
    function notificacaoVisivelPara(dados) {
      return isBackendAdmin()
        || dados.destinatarios == "todos"
        || (dados.keys().hasAny(["destinatarios"]) && request.auth.uid in dados.destinatarios)
        || (dados.keys().hasAny(["uid"]) && dados.uid == request.auth.uid);
    }

    // Cada destinatário pode marcar a própria notificação como lida/não lida
    // sem Cloud Function: só pode tocar em lidoPor/leituraAtualizadaEm, e só
    // pode adicionar OU remover o próprio uid do array (nunca o de outro
    // destinatário). Como lidoPor só contém uids únicos, comparar tamanho +
    // "antes contém tudo de depois" (ou o inverso) garante que a única
    // diferença entre as duas versões é exatamente o próprio uid.
    function leituraNotificacaoPropriaValida() {
      let antes = resource.data.keys().hasAny(["lidoPor"]) && resource.data.lidoPor is list ? resource.data.lidoPor : [];
      let depois = request.resource.data.lidoPor;
      let uid = request.auth.uid;
      return notificacaoVisivelPara(resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["lidoPor", "leituraAtualizadaEm"])
        && depois is list
        && (
          (!(uid in antes) && uid in depois && depois.size() == antes.size() + 1 && depois.hasAll(antes))
          || (uid in antes && !(uid in depois) && antes.size() == depois.size() + 1 && antes.hasAll(depois))
        );
    }

    function validIaConfigData(data, storeUid) {
      return data.keys().hasOnly([
          "ativo", "nomeAssistente", "mensagemApresentacao", "idioma",
          "personalidade", "tamanhoResposta", "instrucoes", "canais",
          "modoRespostaAutomatica", "mensagemFallback", "tenantId", "lojaId",
          "criadoPor", "criadoEm", "atualizadoPor", "atualizadoEm"
        ])
        && data.keys().hasAll([
          "ativo", "nomeAssistente", "mensagemApresentacao", "idioma",
          "personalidade", "tamanhoResposta", "instrucoes", "canais",
          "modoRespostaAutomatica", "mensagemFallback", "tenantId", "lojaId",
          "criadoPor", "criadoEm", "atualizadoPor", "atualizadoEm"
        ])
        && data.tenantId == storeUid
        && data.lojaId == storeUid
        && data.ativo is bool
        && data.nomeAssistente is string
        && data.nomeAssistente.size() >= 2
        && data.nomeAssistente.size() <= 40
        && data.mensagemApresentacao is string
        && data.mensagemApresentacao.size() <= 300
        && data.idioma in ["pt-BR", "en", "es", "automatico"]
        && data.personalidade in ["amigavel", "profissional", "direta", "consultiva", "vendedora", "suporte", "personalizada"]
        && data.tamanhoResposta in ["curta", "media", "detalhada"]
        && data.instrucoes is string
        && data.instrucoes.size() <= 5000
        && data.canais is map
        && data.canais.keys().hasOnly(["lojaPublica", "sugestoesFuncionarios", "respostasAutomaticas", "criacaoConteudo", "whatsapp"])
        && data.canais.keys().hasAll(["lojaPublica", "sugestoesFuncionarios", "respostasAutomaticas", "criacaoConteudo", "whatsapp"])
        && data.canais.lojaPublica is bool
        && data.canais.sugestoesFuncionarios is bool
        && data.canais.respostasAutomaticas is bool
        && data.canais.criacaoConteudo is bool
        && data.canais.whatsapp is bool
        && data.modoRespostaAutomatica in ["nunca", "sempre", "fora_horario", "sem_funcionario"]
        && data.mensagemFallback is string
        && data.mensagemFallback.size() > 0
        && data.mensagemFallback.size() <= 300
        && data.criadoPor is string
        && data.criadoEm is timestamp
        && data.atualizadoPor is string
        && data.atualizadoEm is timestamp;
    }

    function validIaConfigCreate(storeUid) {
      return canEditTenant(storeUid, "central-ia")
        && validIaConfigData(request.resource.data, storeUid)
        && request.resource.data.criadoPor == request.auth.uid
        && request.resource.data.atualizadoPor == request.auth.uid
        && request.resource.data.criadoEm == request.time
        && request.resource.data.atualizadoEm == request.time;
    }

    function validIaConfigUpdate(storeUid) {
      return canEditTenant(storeUid, "central-ia")
        && validIaConfigData(request.resource.data, storeUid)
        && request.resource.data.tenantId == resource.data.tenantId
        && request.resource.data.lojaId == resource.data.lojaId
        && request.resource.data.criadoPor == resource.data.criadoPor
        && request.resource.data.criadoEm == resource.data.criadoEm
        && request.resource.data.atualizadoPor == request.auth.uid
        && request.resource.data.atualizadoEm == request.time;
    }

    // ===== Base de Conhecimento da IA =====
    // Item de conhecimento por tenant. Opções fechadas, limites de tamanho
    // e autoria/timestamps do servidor; metadados de criação imutáveis.
    function validConhecimentoData(data) {
      return data.keys().hasOnly([
          "tenantId", "lojaId", "tipo", "titulo", "conteudo", "resumo",
          "tags", "categoria", "prioridade", "status", "ativo",
          "criadoEm", "criadoPor", "atualizadoEm", "atualizadoPor"
        ])
        && data.keys().hasAll([
          "tenantId", "lojaId", "tipo", "titulo", "conteudo",
          "prioridade", "status", "ativo",
          "criadoEm", "criadoPor", "atualizadoEm", "atualizadoPor"
        ])
        && data.tenantId is string
        && data.lojaId == data.tenantId
        && data.tipo in ["faq", "empresa", "politica", "atendimento", "manual", "produto", "documento", "catalogo"]
        && data.titulo is string
        && data.titulo.size() >= 3
        && data.titulo.size() <= 160
        && data.conteudo is string
        && data.conteudo.size() >= 1
        && data.conteudo.size() <= 8000
        && (!data.keys().hasAny(["resumo"]) || (data.resumo is string && data.resumo.size() <= 300))
        && (!data.keys().hasAny(["categoria"]) || (data.categoria is string && data.categoria.size() <= 80))
        && (!data.keys().hasAny(["tags"]) || (data.tags is list && data.tags.size() <= 10))
        && data.prioridade in ["baixa", "normal", "alta", "critica"]
        && data.status in ["ativo", "rascunho", "arquivado"]
        && data.ativo is bool
        && data.criadoPor is string
        && data.atualizadoPor is string;
    }

    function validConhecimentoCreate() {
      return canEditTenant(request.resource.data.tenantId, "base-conhecimento-ia")
        && validConhecimentoData(request.resource.data)
        && request.resource.data.criadoPor == request.auth.uid
        && request.resource.data.atualizadoPor == request.auth.uid
        && request.resource.data.criadoEm == request.time
        && request.resource.data.atualizadoEm == request.time;
    }

    function validConhecimentoUpdate() {
      return canEditTenant(resource.data.tenantId, "base-conhecimento-ia")
        && validConhecimentoData(request.resource.data)
        && request.resource.data.tenantId == resource.data.tenantId
        && request.resource.data.lojaId == resource.data.lojaId
        && request.resource.data.criadoPor == resource.data.criadoPor
        && request.resource.data.criadoEm == resource.data.criadoEm
        && request.resource.data.atualizadoPor == request.auth.uid
        && request.resource.data.atualizadoEm == request.time;
    }

    // ===== Escritas públicas sem Cloud Functions (plano Spark) =====
    // Métricas: qualquer visitante pode incrementar, desde que o documento
    // corresponda a um conteúdo público real e só toque nas chaves de
    // métrica conhecidas (nada de escrever campos/coleções arbitrárias).
    function metricaLpValida(id) {
      return exists(/databases/$(database)/documents/landing_pages_publicas/$(id))
        && request.resource.data.keys().hasOnly(["totalVisualizacoes", "porDia"]);
    }
    function metricaVitrineValida(id) {
      return exists(/databases/$(database)/documents/usuarios/$(id))
        && request.resource.data.keys().hasOnly(["totalSessoes", "totalTempoTela", "totalCliques", "produtosInteresse", "porDia"]);
    }
    function metricaProdutoValida(id) {
      return exists(/databases/$(database)/documents/produtos/$(id))
        && request.resource.data.keys().hasOnly(["visualizacoes", "cliques"]);
    }
    // Lead público: criadoPor precisa apontar para um dono real e o lead
    // nasce sempre com status "novo" (o visitante não escolhe status).
    function leadPublicoValido() {
      return request.resource.data.keys().hasAll(["criadoPor"])
        && request.resource.data.criadoPor is string
        && request.resource.data.criadoPor != ""
        && exists(/databases/$(database)/documents/usuarios/$(request.resource.data.criadoPor))
        && (!("statusLead" in request.resource.data) || request.resource.data.statusLead == "novo")
        && (!("status" in request.resource.data) || request.resource.data.status == "novo");
    }

    function produtoPublicadoParaAvaliacao() {
      return request.resource.data.keys().hasAll(["produtoId", "criadoPor"])
        && request.resource.data.produtoId is string
        && exists(/databases/$(database)/documents/produtos/$(request.resource.data.produtoId))
        && get(/databases/$(database)/documents/produtos/$(request.resource.data.produtoId)).data.statusProduto != "rascunho"
        && get(/databases/$(database)/documents/produtos/$(request.resource.data.produtoId)).data.criadoPor == request.resource.data.criadoPor;
    }

    function avaliacaoPublicaValida() {
      return request.resource.data.keys().hasOnly([
          "produtoId",
          "criadoPor",
          "nome",
          "nota",
          "comentario",
          "status",
          "data",
          "lojaSlug"
        ])
        && request.resource.data.keys().hasAll(["produtoId", "criadoPor", "nome", "nota", "comentario", "status", "data"])
        && produtoPublicadoParaAvaliacao()
        && request.resource.data.nome is string
        && request.resource.data.nome.size() > 0
        && request.resource.data.nome.size() <= 80
        && request.resource.data.nota is int
        && request.resource.data.nota >= 1
        && request.resource.data.nota <= 5
        && request.resource.data.comentario is string
        && request.resource.data.comentario.size() <= 1000
        && request.resource.data.status == "novo"
        && request.resource.data.data is timestamp
        && (!("lojaSlug" in request.resource.data) || (request.resource.data.lojaSlug is string && request.resource.data.lojaSlug.size() <= 160));
    }

    function moderacaoAvaliacaoValida() {
      return canEditTenant(resource.data.criadoPor, "produtos")
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "moderadoEm", "moderadoPor"])
        && request.resource.data.status in ["novo", "publicada", "rejeitada", "arquivada"]
        && (!request.resource.data.keys().hasAny(["moderadoPor"]) || request.resource.data.moderadoPor == request.auth.uid)
        && (!request.resource.data.keys().hasAny(["moderadoEm"]) || request.resource.data.moderadoEm is timestamp);
    }

    // ===== Central de Atendimento (evolui a coleção chats/mensagens já
    // existente — não é uma estrutura paralela) =====
    //
    // Visitante da loja pública cria o chat e manda mensagens "cliente"
    // direto; dono/funcionário responde com "admin". O id do chat é um
    // token aleatório do Firestore, então serve de capability pro
    // visitante ler as mensagens do próprio chat.
    //
    // status é o campo novo e mais rico (6 estados) usado pela Central de
    // Atendimento; statusAdmin ("pendente"/"respondido") é o campo legado
    // que o widget público sempre gravou e continua gravando — mantido
    // por compatibilidade, sem quebrar o contrato público existente.
    function statusConversaValido(status) {
      return status in ["nova", "aberta", "aguardando_cliente", "aguardando_equipe", "resolvida", "arquivada"];
    }

    function chatPublicoValido() {
      return request.resource.data.keys().hasOnly(["donoUID", "emailDono", "clienteNome", "statusAdmin", "status", "canal", "utmSource", "timestamp", "ultimaMensagem", "atualizadoEm", "criadoEm", "naoLidasLoja"])
        && request.resource.data.keys().hasAll(["donoUID", "clienteNome"])
        && request.resource.data.donoUID is string
        && exists(/databases/$(database)/documents/usuarios/$(request.resource.data.donoUID))
        && request.resource.data.statusAdmin == "pendente"
        && (!request.resource.data.keys().hasAny(["status"]) || request.resource.data.status == "nova")
        && (!request.resource.data.keys().hasAny(["canal"]) || request.resource.data.canal in ["loja_publica", "whatsapp_futuro"])
        && (!request.resource.data.keys().hasAny(["naoLidasLoja"]) || request.resource.data.naoLidasLoja == 1);
    }
    // O visitante só toca no resumo/status ao mandar mensagem — nunca em
    // atribuição, setor ou nos campos administrativos da Central de
    // Atendimento (esses só mudam pela escrita autenticada abaixo).
    function chatUpdatePublicoValido() {
      let antes = resource.data.keys().hasAny(["naoLidasLoja"]) && resource.data.naoLidasLoja is number ? resource.data.naoLidasLoja : 0;
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(["ultimaMensagem", "statusAdmin", "status", "atualizadoEm", "naoLidasLoja"])
        && request.resource.data.statusAdmin == "pendente"
        && (!request.resource.data.keys().hasAny(["status"]) || request.resource.data.status == "aguardando_equipe")
        && (!request.resource.data.keys().hasAny(["naoLidasLoja"]) || request.resource.data.naoLidasLoja == antes + 1)
        && donoUIDUnchanged();
    }
    function podeResponderChat(chatData) {
      return (chatData.keys().hasAny(["donoUID"]) && (canEditTenant(chatData.donoUID, "atendimento") || canEditTenant(chatData.donoUID, "leads")))
        || (chatData.keys().hasAny(["emailDono"]) && (canEditTenant(chatData.emailDono, "atendimento") || canEditTenant(chatData.emailDono, "leads")));
    }
    // "arquivada" não recebe mensagem sem ser reaberta antes (escrita
    // separada de status, feita por quem atende). Docs antigos sem o
    // campo status ainda não existiam quando essa regra foi criada, então
    // contam como "não arquivada".
    function chatNaoArquivado(chatData) {
      return !chatData.keys().hasAny(["status"]) || chatData.status != "arquivada";
    }
    function mensagemClienteValida(chatId) {
      let chatRef = /databases/$(database)/documents/chats/$(chatId);
      return exists(chatRef)
        && chatNaoArquivado(get(chatRef).data)
        && request.resource.data.sender == "cliente"
        && request.resource.data.keys().hasOnly(["texto", "sender", "timestamp", "criadoEm", "autorTipo"])
        && request.resource.data.texto is string
        && request.resource.data.texto.size() > 0
        && request.resource.data.texto.size() <= 4000
        && (!request.resource.data.keys().hasAny(["autorTipo"]) || request.resource.data.autorTipo == "cliente");
    }
    // autorNome não é revalidado contra o cadastro (custaria mais um
    // get() por escrita) — a confiança vem de nenhuma tela oferecer um
    // campo de nome livre nesse fluxo; o valor é sempre derivado do
    // contexto autenticado no cliente (mesmo modelo de confiança usado em
    // criadoPor por toda a base). autorUid, em contrapartida, É
    // revalidado aqui contra request.auth.uid — não dá pra falsificar.
    function mensagemAdminValida(chatId) {
      let chatRef = /databases/$(database)/documents/chats/$(chatId);
      return exists(chatRef)
        && chatNaoArquivado(get(chatRef).data)
        && podeResponderChat(get(chatRef).data)
        && request.resource.data.sender == "admin"
        && request.resource.data.keys().hasOnly(["texto", "sender", "timestamp", "criadoEm", "autorTipo", "autorUid", "autorNome"])
        && request.resource.data.texto is string
        && request.resource.data.texto.size() > 0
        && request.resource.data.texto.size() <= 4000
        && request.resource.data.autorUid == request.auth.uid
        && request.resource.data.autorTipo in ["funcionario", "proprietario"]
        && (!request.resource.data.keys().hasAny(["autorNome"]) || (request.resource.data.autorNome is string && request.resource.data.autorNome.size() <= 120));
    }

    // Atribuição só para o próprio dono ou um funcionário ativo do MESMO
    // tenant — nunca um uid arbitrário, nunca de outra loja.
    function funcionarioAtivoDoTenant(uid, donoUID) {
      let dados = get(/databases/$(database)/documents/funcionarios/$(uid)).data;
      return dados.donoUID == donoUID
        && dados.status == "ativo"
        && employeeHasPermissionShape(dados)
        && (
          employeeHasModulePermission(dados.permissoes.ver, "atendimento")
          || employeeHasModulePermission(dados.permissoes.editar, "atendimento")
          || employeeHasModulePermission(dados.permissoes.ver, "leads")
          || employeeHasModulePermission(dados.permissoes.editar, "leads")
        );
    }
    function atribuicaoChatValida(donoUID) {
      let mudou = request.resource.data.diff(resource.data).affectedKeys().hasAny(["atribuidoPara"]);
      let alvo = request.resource.data.atribuidoPara;
      return !mudou
        || alvo == ""
        || alvo == donoUID
        || (exists(/databases/$(database)/documents/funcionarios/$(alvo)) && funcionarioAtivoDoTenant(alvo, donoUID));
    }
    // Escrita autenticada do dono/funcionário no próprio chat: permissão
    // (atendimento OU leads, compatibilidade com quem só tinha leads
    // antes), tenant imutável, status dentro do enum, atribuição
    // validada, sem campos fora da lista conhecida da Central de
    // Atendimento.
    function chatAdminUpdateValido() {
      let donoUID = hasTenantField("donoUID") ? resource.data.donoUID : resource.data.emailDono;
      return podeResponderChat(resource.data)
        && donoUIDUnchanged()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "status", "statusAdmin", "setor", "atribuidoPara", "atribuidoPor", "atribuidoEm",
            "statusAtualizadoPor", "statusAtualizadoEm", "ultimaMensagem", "atualizadoEm",
            "naoLidasLoja", "naoLidasCliente", "observacoesInternas", "tags"
          ])
        && (!request.resource.data.keys().hasAny(["status"]) || statusConversaValido(request.resource.data.status))
        && (!request.resource.data.keys().hasAny(["setor"]) || (request.resource.data.setor is string && request.resource.data.setor.size() <= 80))
        && (!request.resource.data.keys().hasAny(["observacoesInternas"]) || (request.resource.data.observacoesInternas is string && request.resource.data.observacoesInternas.size() <= 2000))
        && (!request.resource.data.keys().hasAny(["tags"]) || (request.resource.data.tags is list && request.resource.data.tags.size() <= 10))
        && atribuicaoChatValida(donoUID);
    }

    function publicStoreFields() {
      return [
        "donoUID",
        "emailDono",
        "nomeLoja",
        "tituloHero",
        "subtituloHero",
        "whatsappCentral",
        "chatAtivo",
        "carrinhoAtivo",
        "carrinhoMensagem",
        "corClientBrand",
        "corClientFundo",
        "corClientCard",
        "corClientSecundaria",
        "corClientTexto",
        "corClientTextoBotao",
        "corClientBorda",
        "fonteVitrine",
        "fotoPerfilB64",
        "link1Titulo",
        "link1Url",
        "link1Icone",
        "link2Titulo",
        "link2Url",
        "link2Icone",
        "layoutLojaPublica",
        "atualizadoEm"
      ];
    }

    function publicBannerFields() {
      return ["donoUID", "imagemB64", "ordem", "atualizadoEm"];
    }

    function publicLandingPageFields() {
      return ["titulo", "publicado", "donoUID", "modoLayout", "paginas", "ordemBlocos", "atualizadoEm", "criadoEm"];
    }

    function publicLandingBlockFields() {
      return ["lpId", "donoUID", "tipo", "props", "visivel", "paginaId", "nome", "ordem", "styles", "estilos", "atualizadoEm", "criadoEm"];
    }

    function hasTenantField(fieldName) {
      return resource.data.keys().hasAny([fieldName]);
    }

    function canViewCampaignHistory() {
      return (
        resource.data.keys().hasAny(["uid"])
        && canViewTenant(resource.data.uid, "campanhas")
      ) || (
        resource.data.keys().hasAny(["criadoPor"])
        && canViewTenant(resource.data.criadoPor, "campanhas")
      );
    }

    function canCreateCampaignHistory() {
      return (
        request.resource.data.keys().hasAny(["uid"])
        && canEditTenant(request.resource.data.uid, "campanhas")
      ) || (
        request.resource.data.keys().hasAny(["criadoPor"])
        && canEditTenant(request.resource.data.criadoPor, "campanhas")
      );
    }

    match /usuarios/{ownerUid} {
      // Leitura aqui é resolução de identidade/sessão (core/vide-context.js lê
      // usuarios/{donoUID} pra QUALQUER funcionário logar, não é o módulo
      // "configuracoes"). Gatear por canViewTenant(ownerUid, "configuracoes")
      // impedia login de todo funcionário sem acesso a esse módulo específico.
      // Edição continua exigindo a permissão de editar "configuracoes".
      allow read: if isOwner(ownerUid) || isActiveEmployeeFor(ownerUid) || isBackendAdmin();
      allow create: if validOwnerCreate(ownerUid);
      allow update: if validOwnerProfileUpdate(ownerUid) || isBackendAdmin();
      allow delete: if false;
    }

    match /funcionarios/{employeeUid} {
      allow read: if signedIn()
        && (
          request.auth.uid == employeeUid
          || isOwner(resource.data.donoUID)
          || employeeCanView(resource.data.donoUID, "funcionarios")
          || isBackendAdmin()
        );
      // Modelo Spark (sem Cloud Functions): o DONO gerencia os próprios
      // funcionários por escrita direta. A conta de Auth do funcionário é
      // criada por um app Firebase secundário no navegador; aqui só se
      // valida o documento de vínculo/permissões.
      //
      // Só o dono (nunca um funcionário, mesmo com edição de
      // "funcionarios") — o "capping" de permissões que a antiga Cloud
      // Function fazia (funcionário não conceder mais do que tem) não é
      // reproduzível em regras com segurança equivalente; a alternativa
      // segura é restringir a gestão ao dono do tenant.
      allow create: if isBackendAdmin() || (
        isOwner(request.resource.data.donoUID)
        && request.auth.uid != employeeUid
        && request.resource.data.keys().hasOnly([
          "donoUID", "nome", "email", "cargo", "status",
          "senhaTemporaria", "permissoes", "criadoEm", "criadoPorAuthUid"
        ])
        && request.resource.data.keys().hasAll(["donoUID", "nome", "email", "status", "permissoes", "criadoEm"])
        && request.resource.data.nome is string
        && request.resource.data.nome.size() >= 1
        && request.resource.data.nome.size() <= 120
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 160
        && request.resource.data.status == "ativo"
        && employeeHasPermissionShape(request.resource.data)
        && request.resource.data.criadoEm == request.time
        && (!request.resource.data.keys().hasAny(["criadoPorAuthUid"]) || request.resource.data.criadoPorAuthUid == request.auth.uid)
        && (!request.resource.data.keys().hasAny(["cargo"]) || (request.resource.data.cargo is string && request.resource.data.cargo.size() <= 120))
      );
      allow update: if isBackendAdmin() || (
        isOwner(resource.data.donoUID)
        && request.auth.uid != employeeUid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "nome", "cargo", "permissoes", "status",
          "senhaTemporaria", "atualizadoEm", "atualizadoPorAuthUid"
        ])
        && request.resource.data.status in ["ativo", "inativo"]
        && employeeHasPermissionShape(request.resource.data)
        && request.resource.data.nome is string
        && request.resource.data.nome.size() >= 1
        && request.resource.data.nome.size() <= 120
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(["atualizadoPorAuthUid"]) || request.resource.data.atualizadoPorAuthUid == request.auth.uid)
      );
      // Sem delete físico: desativação (status "inativo") é a exclusão lógica.
      allow delete: if false;
    }

    match /produtos/{id} {
      allow read: if resource.data.statusProduto != "rascunho"
        || canViewTenant(resource.data.criadoPor, "produtos");
      allow create: if canEditTenant(request.resource.data.criadoPor, "produtos");
      allow update: if criadoPorUnchanged() && canEditTenant(resource.data.criadoPor, "produtos");
      allow delete: if canEditTenant(resource.data.criadoPor, "produtos");
    }

    match /avaliacoes/{id} {
      allow read: if resource.data.status == "publicada"
        || canViewTenant(resource.data.criadoPor, "produtos");
      allow create: if avaliacaoPublicaValida();
      allow update: if moderacaoAvaliacaoValida();
      allow delete: if false;
    }

    match /pedidos/{id} {
      allow read: if canViewTenant(resource.data.criadoPor, "pedidos");
      allow create: if canEditTenant(request.resource.data.criadoPor, "pedidos");
      allow update: if criadoPorUnchanged() && canEditTenant(resource.data.criadoPor, "pedidos");
      allow delete: if canEditTenant(resource.data.criadoPor, "pedidos");
    }

    match /leads/{id} {
      allow read: if canViewTenant(resource.data.criadoPor, "leads");
      // Captura pública (LP/loja) escreve direto — validada por leadPublicoValido().
      // O dono/funcionário também pode cadastrar lead manualmente pelo painel.
      allow create: if leadPublicoValido()
        || canEditTenant(request.resource.data.criadoPor, "leads");
      allow update: if criadoPorUnchanged() && canEditTenant(resource.data.criadoPor, "leads");
      allow delete: if canEditTenant(resource.data.criadoPor, "leads");
    }

    // Template de mensagem — usado tanto pelo fluxo de automação de leads
    // (campo "fluxo", já existente) quanto pelas respostas prontas da
    // Central de Atendimento (categoria/atalho/ativo, novos). Mesma
    // coleção, mesmo dono; nunca conteúdo executável (só texto).
    function validTemplateFluxo(fluxo) {
      return fluxo.keys().hasOnly(["ativo", "statusLead", "followupDias", "prioridade", "anotacao"])
        && (!fluxo.keys().hasAny(["ativo"]) || fluxo.ativo is bool)
        && (!fluxo.keys().hasAny(["followupDias"]) || fluxo.followupDias is number)
        && (!fluxo.keys().hasAny(["anotacao"]) || (fluxo.anotacao is string && fluxo.anotacao.size() <= 500));
    }
    function validTemplateData(data) {
      return data.keys().hasOnly(["titulo", "mensagem", "categoria", "atalho", "ativo", "fluxo", "criadoPor", "criadoEm", "atualizadoEm"])
        && data.keys().hasAll(["titulo", "mensagem", "categoria", "criadoPor"])
        && data.titulo is string && data.titulo.size() >= 1 && data.titulo.size() <= 160
        && data.mensagem is string && data.mensagem.size() >= 1 && data.mensagem.size() <= 2000
        && data.categoria is string && data.categoria.size() <= 60
        && data.criadoPor is string
        && (!data.keys().hasAny(["atalho"]) || (data.atalho is string && data.atalho.size() <= 40))
        && (!data.keys().hasAny(["ativo"]) || data.ativo is bool)
        && (!data.keys().hasAny(["fluxo"]) || (data.fluxo is map && validTemplateFluxo(data.fluxo)));
    }

    match /templates/{id} {
      allow read: if canViewTenant(resource.data.criadoPor, "templates");
      allow create: if canEditTenant(request.resource.data.criadoPor, "templates") && validTemplateData(request.resource.data);
      allow update: if criadoPorUnchanged() && canEditTenant(resource.data.criadoPor, "templates") && validTemplateData(request.resource.data);
      allow delete: if canEditTenant(resource.data.criadoPor, "templates");
    }

    match /campanhas/{ownerUid} {
      allow read: if canViewTenant(ownerUid, "campanhas");
      allow write: if canEditTenant(ownerUid, "campanhas");
    }

    match /configuracoes_ia/{storeUid} {
      allow read: if canViewTenant(storeUid, "central-ia");
      allow create: if validIaConfigCreate(storeUid);
      allow update: if validIaConfigUpdate(storeUid);
      allow delete: if false;
    }

    // ===== Base de Conhecimento da IA (por tenant) =====
    // Itens que alimentarão a futura assistente: FAQ, dados da empresa,
    // políticas, manuais etc. Escrita direta (Spark), sempre presa ao
    // tenant autenticado. Sem delete físico: arquivar é a exclusão lógica.
    match /base_conhecimento_ia/{id} {
      allow read: if resource.data.keys().hasAny(["tenantId"])
        && canViewTenant(resource.data.tenantId, "base-conhecimento-ia");
      allow create: if validConhecimentoCreate();
      allow update: if validConhecimentoUpdate();
      allow delete: if false;
    }

    match /campanhas_historico/{id} {
      allow read: if canViewCampaignHistory();
      allow create: if canCreateCampaignHistory();
      allow update, delete: if isBackendAdmin();
    }

    match /vitrines_publicas/{slug} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(publicStoreFields())
        && request.resource.data.keys().hasAll(["donoUID"])
        && canEditTenant(request.resource.data.donoUID, "configuracoes");
      allow update: if request.resource.data.keys().hasOnly(publicStoreFields())
        && donoUIDUnchanged()
        && canEditTenant(resource.data.donoUID, "configuracoes");
      allow delete: if canEditTenant(resource.data.donoUID, "configuracoes");
    }

    match /banners_loja/{id} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(publicBannerFields())
        && request.resource.data.keys().hasAll(["donoUID"])
        && canEditTenant(request.resource.data.donoUID, "configuracoes");
      allow update: if request.resource.data.keys().hasOnly(publicBannerFields())
        && donoUIDUnchanged()
        && canEditTenant(resource.data.donoUID, "configuracoes");
      allow delete: if canEditTenant(resource.data.donoUID, "configuracoes");
    }

    match /landing_pages/{id} {
      allow read: if canViewTenant(resource.data.donoUID, "landing-pages");
      allow create: if canEditTenant(request.resource.data.donoUID, "landing-pages");
      allow update: if donoUIDUnchanged() && canEditTenant(resource.data.donoUID, "landing-pages");
      allow delete: if canEditTenant(resource.data.donoUID, "landing-pages");
    }

    match /landing_pages_blocos/{id} {
      allow read: if canViewTenant(resource.data.donoUID, "landing-pages");
      allow create: if canEditTenant(request.resource.data.donoUID, "landing-pages");
      allow update: if donoUIDUnchanged() && canEditTenant(resource.data.donoUID, "landing-pages");
      allow delete: if canEditTenant(resource.data.donoUID, "landing-pages");
    }

    match /landing_pages_publicas/{id} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(publicLandingPageFields())
        && request.resource.data.keys().hasAll(["donoUID"])
        && canEditTenant(request.resource.data.donoUID, "landing-pages");
      allow update: if request.resource.data.keys().hasOnly(publicLandingPageFields())
        && donoUIDUnchanged()
        && canEditTenant(resource.data.donoUID, "landing-pages");
      allow delete: if canEditTenant(resource.data.donoUID, "landing-pages");
    }

    match /landing_pages_blocos_publicas/{id} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(publicLandingBlockFields())
        && request.resource.data.keys().hasAll(["donoUID"])
        && canEditTenant(request.resource.data.donoUID, "landing-pages");
      allow update: if request.resource.data.keys().hasOnly(publicLandingBlockFields())
        && donoUIDUnchanged()
        && canEditTenant(resource.data.donoUID, "landing-pages");
      allow delete: if canEditTenant(resource.data.donoUID, "landing-pages");
    }

    match /notificacoes/{id} {
      // Cada ramo aqui precisa corresponder a um filtro que o dashboard
      // consiga usar numa query (where) pra que list() funcione sem
      // escanear a coleção inteira — dashboard-app.js fazia isso sem filtro
      // nenhum, e o Firestore recusa list() sempre que a regra depende de
      // resource.data sem um filtro correspondente provável pra cada
      // resultado possível.
      allow read: if signedIn() && notificacaoVisivelPara(resource.data);
      allow create, delete: if isBackendAdmin();
      // Marcar como lida/não lida é uma escrita direta do próprio
      // destinatário (sem Cloud Function, plano Spark); qualquer outra
      // alteração continua exigindo admin.
      allow update: if isBackendAdmin() || leituraNotificacaoPropriaValida();
    }

    match /solicitacoes_customizacao/{id} {
      allow read: if (
        resource.data.keys().hasAny(["uid"])
        && canViewTenant(resource.data.uid, "configuracoes")
      ) || isBackendAdmin();
      allow create: if request.resource.data.keys().hasAll(["uid", "tipo", "descricao", "status", "criadoEm"])
        && canEditTenant(request.resource.data.uid, "configuracoes")
        && request.resource.data.keys().hasOnly([
          "uid",
          "tipo",
          "descricao",
          "status",
          "criadoEm",
          "atualizadoEm",
          "anotacaoAdmin"
        ])
        && request.resource.data.status == "pendente";
      allow update, delete: if isBackendAdmin();
    }

    match /auditoria/{id} {
      allow read: if isBackendAdmin();
      allow create, update, delete: if false;
    }

    match /config/tema_sistema {
      // login.html carrega isso antes do usuário entrar (branding do sistema),
      // então precisa ser público. Não é dado por tenant nem sensível.
      allow read: if true;
      allow write: if isBackendAdmin();
    }

    match /config/{id} {
      allow read: if signedIn();
      allow write: if isBackendAdmin();
    }

    match /equipe_admin/{id} {
      allow read, write: if isBackendAdmin();
    }

    match /metricas_vitrines/{id} {
      allow read: if canViewTenant(id, "metricas");
      // Incremento público (sessões/tempo/cliques da loja) — só chaves de métrica.
      allow create, update: if metricaVitrineValida(id);
      allow delete: if false;
    }

    match /metricas_produtos/{id} {
      allow read: if exists(/databases/$(database)/documents/produtos/$(id))
        && canViewTenant(get(/databases/$(database)/documents/produtos/$(id)).data.criadoPor, "metricas");
      // Incremento público (visualizações/cliques do produto) — só chaves de métrica.
      allow create, update: if metricaProdutoValida(id);
      allow delete: if false;
    }

    match /metricas_landing_pages/{id} {
      allow read: if exists(/databases/$(database)/documents/landing_pages_publicas/$(id))
        && canViewTenant(get(/databases/$(database)/documents/landing_pages_publicas/$(id)).data.donoUID, "metricas");
      // Incremento público de visualizações — amarrado a uma LP publicada real.
      allow create, update: if metricaLpValida(id);
      allow delete: if false;
    }

    match /chats/{chatId} {
      allow read: if signedIn()
        && (
          isBackendAdmin()
          || (hasTenantField("emailDono") && (canViewTenant(resource.data.emailDono, "atendimento") || canViewTenant(resource.data.emailDono, "leads")))
          || (hasTenantField("donoUID") && (canViewTenant(resource.data.donoUID, "atendimento") || canViewTenant(resource.data.donoUID, "leads")))
        );
      // Visitante da loja cria o chat direto (validado); dono/funcionário
      // também pode (conversa interna, ex.: registrar um atendimento por
      // outro canal) — mesma validação de chaves/tipos do fluxo público,
      // só que sem exigir statusAdmin/status fixos.
      allow create: if chatPublicoValido()
        || (
          canEditTenant(request.resource.data.donoUID, "atendimento") || canEditTenant(request.resource.data.donoUID, "leads")
        ) && request.resource.data.keys().hasOnly(["donoUID", "emailDono", "clienteNome", "statusAdmin", "status", "canal", "setor", "utmSource", "timestamp", "ultimaMensagem", "atualizadoEm", "criadoEm", "naoLidasLoja", "naoLidasCliente"])
          && request.resource.data.keys().hasAll(["donoUID", "clienteNome"])
          && (!request.resource.data.keys().hasAny(["status"]) || statusConversaValido(request.resource.data.status))
          && (!request.resource.data.keys().hasAny(["canal"]) || request.resource.data.canal in ["loja_publica", "interno", "whatsapp_futuro"]);
      // Visitante só mexe em resumo/status ao mandar mensagem; dono/funcionário
      // usa o caminho validado da Central de Atendimento (status, atribuição,
      // setor, observações — nunca doar tenant nem inventar campo novo).
      allow update: if chatUpdatePublicoValido() || chatAdminUpdateValido();
      allow delete: if (hasTenantField("donoUID") && (canEditTenant(resource.data.donoUID, "atendimento") || canEditTenant(resource.data.donoUID, "leads")))
        || (hasTenantField("emailDono") && (canEditTenant(resource.data.emailDono, "atendimento") || canEditTenant(resource.data.emailDono, "leads")));

      match /mensagens/{msgId} {
        // Visitante não autenticado: conhecer o id do chat (token aleatório)
        // já é a capability de leitura — é assim que o próprio widget lê a
        // conversa que acabou de criar, sem Auth. Usuário autenticado: só
        // lê se realmente pertencer ao tenant dono do chat (dono, admin
        // backend ou funcionário com permissão) — sem esse recorte, outro
        // dono autenticado que soubesse/adivinhasse o id conseguiria ler
        // mensagens de um tenant alheio.
        allow read: if
          (!signedIn() && exists(/databases/$(database)/documents/chats/$(chatId)))
          || (
            signedIn()
            && exists(/databases/$(database)/documents/chats/$(chatId))
            && (
              isBackendAdmin()
              || podeResponderChat(get(/databases/$(database)/documents/chats/$(chatId)).data)
            )
          );
        // Cliente cria mensagem "cliente"; dono/funcionário cria "admin".
        allow create: if mensagemClienteValida(chatId) || mensagemAdminValida(chatId);
        allow update, delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
